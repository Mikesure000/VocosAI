# Server
HOST=127.0.0.1
PORT=8787
NODE_ENV=development

# Database
DATABASE_URL=file:./data/vocosai.sqlite

# JWT
JWT_SECRET=replace-with-a-long-random-secret

# AI Model Gateway
VOCOS_MODEL_MODE=live
VOCOS_PRIMARY_PROVIDER=deepseek
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_REASONING_MODEL=deepseek-v4-pro

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_MODEL=gpt-4.1
OPENAI_MINI_MODEL=gpt-4.1-mini

# Encryption for stored API keys
VOCOS_KEY_ENCRYPTION_SECRET=replace-with-another-random-secret

# Cost Governance
VOCOS_MONTHLY_QUOTA=1000000
VOCOS_TASK_COST_LIMIT=12.00
